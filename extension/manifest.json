{
  "manifest_version": 3,
  "name": "One-Click Video Downloader",
  "description": "Detect and locally save authorized page videos with automatic stream merging.",
  "version": "0.2.0",
  "minimum_chrome_version": "102",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "One-Click Video Downloader",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "optional_permissions": [
    "cookies",
    "power",
    "scripting"
  ]
}
